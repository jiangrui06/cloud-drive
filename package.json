{
  "name": "cloud-drive",
  "version": "1.0.0",
  "description": "企业级网盘管理系统 - 支持多方式登录、用户与群组管理、文件秒传、在线编辑",
  "private": true,
  "scripts": {
    "start": "node server/app.js",
    "dev": "node server/app.js",
    "init-db": "node server/models/init.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop cloud-drive",
    "pm2:restart": "pm2 restart cloud-drive",
    "pm2:logs": "pm2 logs cloud-drive",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "uuid": "^14.0.0"
  }
}
